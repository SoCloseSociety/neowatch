# ── NEOWATCH configuration ───────────────────────────────────────────────
# Copy to .env and adjust. All values are optional (sane defaults baked in).

# Node environment. "production" enforces an explicit JWT_SECRET at boot and
# persists sessions across restarts; "development" auto-generates an ephemeral
# secret (tokens reset on restart).
NODE_ENV=development

# Port the API/proxy server listens on (in production it also serves the built web app).
PORT=8787

# How long (hours) the iptv-org catalog is cached on disk before refetch.
CATALOG_TTL_HOURS=12

# Base of the iptv-org public API (no trailing slash).
IPTV_API_BASE=https://iptv-org.github.io/api

# Hide adult (NSFW) channels everywhere. Strongly recommended to keep true.
HIDE_NSFW=true

# Optional shared access password for a deployed instance (leave empty to disable).
# When set, the web app asks for it once and stores a token locally.
ACCESS_PASSWORD=

# Comma-separated allowed origins for CORS in production (empty = same-origin only).
ALLOWED_ORIGINS=

# Express "trust proxy" so rate limiting sees the real client IP behind nginx.
# e.g. 1 (one proxy hop) or "loopback". Leave empty if not behind a proxy.
TRUST_PROXY=

# Allow admin-added M3U sources to point at private/LAN hosts (your own provider
# on the local network). Off by default (blocks SSRF). Set true only if you trust it.
ALLOW_PRIVATE_SOURCES=false

# ── Authentication & accounts ──────────────────────────────────────────
# When true, the catalog/proxy require a logged-in user (SaaS/VPS mode).
REQUIRE_AUTH=false
# Allow visitors to self-register a free account.
ALLOW_REGISTER=true
# REQUIRED in production: a long random secret so JWT tokens + signed proxy URLs
# survive restarts. If empty in dev, a random one is generated each boot.
JWT_SECRET=
# Token lifetime (e.g. 7d, 24h). Shorter = smaller blast radius if a token leaks.
JWT_TTL=7d
# Optional dedicated secret for HMAC proxy-URL signing (defaults to a value
# derived from JWT_SECRET, so key separation holds without setting this).
SIGNING_SECRET=
# First-boot admin account. If ADMIN_PASSWORD is empty, a random one is printed once.
ADMIN_EMAIL=admin@neowatch.local
ADMIN_PASSWORD=
# Imported M3U sources are Premium by default (set false to make them free).
CUSTOM_PREMIUM=true

# ── Monetization ───────────────────────────────────────────────────────
# Channels in these categories require Premium; the rest are free (ad-supported).
PREMIUM_CATEGORIES=sports,movies,series
PREMIUM_PRICE=4.99
PREMIUM_CURRENCY=EUR
PREMIUM_PERIOD_DAYS=30
# Public origin (used for Stripe success/cancel URLs).
PUBLIC_URL=https://neowatch.soclose.co
# Billing provider: "mock" (instant, dev/self-host) or "stripe" (real).
BILLING_PROVIDER=mock
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Google AdSense publisher id (ca-pub-...) shown to FREE users only.
ADSENSE_CLIENT=

# ── Health sweep / EPG ─────────────────────────────────────────────────
HEALTH_SWEEP=false
HEALTH_SWEEP_INTERVAL_HOURS=6
# Sweep tuning (lower = gentler on CPU/bandwidth).
SWEEP_BATCH_SIZE=60
SWEEP_CONCURRENCY=8
# Optional default XMLTV EPG (your provider's guide or a public aggregator).
EPG_DEFAULT_URL=
EPG_DEFAULT_TZ_MINUTES=0
